{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "types/**"]
    },
    "build-docs": {},
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "lint": {},
    "lint-fix": {},
    "test": {
      "cache": false,
      "dependsOn": ["^build"],
      "interactive": true
    },
    "test-run": {
      "dependsOn": ["^build"]
    },
    "test-coverage": {
      "outputs": ["coverage/**"],
      "dependsOn": ["^build"],
      "interactive": true
    },
    "test-run-coverage": {
      "outputs": ["coverage/**"],
      "dependsOn": ["^build"]
    },
    "test-run-snapshot": {
      "dependsOn": ["^build"]
    },
    "format": {},
    "check-format": {},
    "clean": {
      "cache": false
    },
    "clean-dist": {
      "cache": false
    }
  }
}
