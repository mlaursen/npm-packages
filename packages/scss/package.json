{
  "name": "@mlaursen/scss",
  "version": "0.0.2",
  "description": "Common utils for compiling sass",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean-dist": "rm -rf dist",
    "clean-cache": "rm -rf .turbo  node_modules",
    "clean": "concurrently 'pnpm clean-dist' 'pnpm clean-cache'",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "lint": "eslint .",
    "lint-fix": "pnpm lint --fix",
    "typecheck": "tsc --noEmit",
    "typecheck-watch": "tsc --noEmit --watch",
    "build-dist": "rollup -c rollup.config.ts",
    "build-dist-watch": "pnpm build-dist --watch",
    "build-types": "tsc -p tsconfig.types.json",
    "build-types-watch": "pnpm build-types --watch",
    "build-docs": "simple-docs",
    "build": "pnpm build-types && pnpm build-dist",
    "test": "vitest",
    "test-coverage": "vitest --coverage",
    "test-run": "vitest run",
    "test-run-snapshot": "vitest run -u",
    "test-run-coverage": "vitest run --coverage",
    "dev": "concurrently 'pnpm build-types-watch' 'pnpm build-dist-watch'"
  },
  "author": "Mikkel Laursen <mlaursen03@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mlaursen/npm-packages.git",
    "directory": "packages/sass"
  },
  "bugs": {
    "url": "https://github.com/mlaursen/npm-packages/issues"
  },
  "keywords": [
    "release",
    "script",
    "npm"
  ],
  "license": "MIT",
  "dependencies": {
    "postcss": "^8.5.13",
    "postcss-selector-parser": "^7.1.1",
    "sass": "^1.99.0"
  },
  "devDependencies": {
    "@mlaursen/eslint-config": "workspace:*",
    "@mlaursen/simple-docs": "workspace:*",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-swc3": "^0.12.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "volta": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  }
}
