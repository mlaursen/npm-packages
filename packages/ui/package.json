{
  "name": "@mlaursen/ui",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "node-run": "node --experimental-strip-types",
    "test-scss": "pnpm node-run scripts/test-scss.ts",
    "test-clean-generated": "git clean -ndX src",
    "clean-generated": "git clean -fdXq src",
    "clean-dist": "rm -rf dist",
    "clean-cache": "rm -rf .turbo node_modules",
    "clean": "concurrently 'pnpm clean-dist' 'pnpm clean-generated' 'pnpm clean-cache'",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "lint": "eslint .",
    "lint-fix": "pnpm lint --fix",
    "typecheck": "tsc --noEmit",
    "typecheck-watch": "tsc --noEmit --watch",
    "build-scss": "pnpm node-run scripts/scss-to-ts.ts",
    "build-scss-watch": "pnpm build-scss --watch",
    "build-esm": "swc -d ./dist --strip-leading-paths --ignore src/index.ts src",
    "build-esm-watch": "pnpm build-esm --watch",
    "build-rollup": "rollup -c rollup.config.ts",
    "build-rollup-watch": "pnpm build-dist --watch",
    "build-dist": "pnpm build-esm && pnpm build-rollup",
    "build-dist-watch": "concurrently 'pnpm build-esm-watch' 'pnpm build-rollup-watch'",
    "build-types": "tsc -p tsconfig.types.json",
    "build-types-watch": "pnpm build-types --watch",
    "build": "pnpm build-scss && pnpm build-types && pnpm build-dist",
    "dev-server": "wds --node-resolve --open dev/ --watch",
    "dev": "pnpm build-scss && concurrently 'pnpm build-scss-watch' 'pnpm build-types-watch' 'pnpm build-dist-watch' --kill-others"
  },
  "author": "Mikkel Laursen <mlaursen03@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mlaursen/npm-packages.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/mlaursen/npm-packages/issues"
  },
  "keywords": [
    "ui",
    "web components",
    "lit"
  ],
  "license": "MIT",
  "dependencies": {
    "@mlaursen/utils": "workspace:*",
    "@open-wc/form-control": "^1.0.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@mlaursen/eslint-config": "workspace:*",
    "@mlaursen/node-utils": "workspace:*",
    "@mlaursen/scss": "workspace:*",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.32",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.12.2",
    "@web/dev-server": "^0.4.6",
    "browserslist": "^4.28.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "glob": "^13.0.6",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "rollup-plugin-summary": "^3.0.1",
    "rollup-plugin-swc3": "^0.12.1",
    "ts-lit-plugin": "^2.0.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "volta": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  }
}
