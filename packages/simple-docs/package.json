{
  "name": "@mlaursen/simple-docs",
  "version": "0.0.1",
  "description": "A simple package for adding @example typedoc to a README",
  "type": "module",
  "private": true,
  "bin": {
    "simple-docs": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/generate.d.ts",
      "default": "./dist/generate.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean-dist": "rm -rf dist",
    "clean-cache": "rm -rf .turbo  node_modules",
    "clean": "concurrently 'pnpm clean-dist' 'pnpm clean-cache'",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "lint": "eslint .",
    "lint-fix": "pnpm lint --fix",
    "typecheck": "tsc --noEmit",
    "typecheck-watch": "tsc --noEmit --watch",
    "build-dist": "rollup -c rollup.config.ts",
    "build-dist-watch": "pnpm build-dist --watch",
    "build-types": "tsc -p tsconfig.types.json",
    "build-types-watch": "pnpm build-types --watch",
    "build": "pnpm build-types && pnpm build-dist",
    "dev": "concurrently 'pnpm build-types-watch' 'pnpm build-dist-watch'"
  },
  "author": "Mikkel Laursen <mlaursen03@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mlaursen/npm-packages.git",
    "directory": "packages/simple-docs"
  },
  "bugs": {
    "url": "https://github.com/mlaursen/npm-packages/issues"
  },
  "keywords": [
    "typedoc",
    "readme"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.18"
  },
  "devDependencies": {
    "@mlaursen/eslint-config": "workspace:*",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "rollup": "^4.60.1",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-swc3": "^0.12.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "volta": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  }
}
