{
  "name": "npm-packages",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "turbo-s": "cross-env TURBO_NO_UPDATE_NOTIFIER=1 TURBO_TELEMETRY_DISABLED=1 turbo",
    "format": "pnpm turbo-s format",
    "check-format": "pnpm turbo-s check-format",
    "dev": "pnpm turbo-s dev",
    "lint": "pnpm turbo-s lint",
    "lint-fix": "pnpm turbo-s lint-fix",
    "test": "TURBO_UI=true pnpm turbo-s test",
    "test-coverage": "TURBO_UI=true pnpm turbo-s test-coverage",
    "test-run": "pnpm turbo-s test-run",
    "test-run-snapshot": "pnpm turbo-s test-run-snapshot",
    "test-run-coverage": "pnpm turbo-s test-run-coverage",
    "typecheck": "pnpm turbo-s typecheck",
    "typecheck-watch": "pnpm turbo-s typecheck-watch",
    "build": "pnpm turbo-s build",
    "build-docs": "pnpm turbo-s build-docs",
    "build-dist": "pnpm build",
    "clean-dist": "pnpm turbo-s clean-dist",
    "clean-other": "pnpm turbo-s clean",
    "clean-root": "rm -rf .turbo node_modules",
    "clean": "pnpm clean-other && pnpm clean-root",
    "release": "tsx scripts/release.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "turbo": "^2.9.7"
  },
  "lint-staged": {
    "**/*.{scss,js,jsx,md,yml,json,ts,tsx}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  },
  "engineStrict": true,
  "packageManager": "pnpm@10.33.0",
  "volta": {
    "node": "24.14.1",
    "pnpm": "10.33.0"
  },
  "workspaces": [
    "packages/cli",
    "packages/copy-scss-files",
    "packages/eslint-config",
    "packages/node-utils",
    "packages/release-script",
    "packages/scss",
    "packages/simple-docs",
    "packages/ui",
    "packages/utils"
  ]
}
