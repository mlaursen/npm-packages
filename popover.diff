+
+    case "right":
+      return {
+        x: 0,
+        actualX: position,
+      };
+    case "inner-right": {
+      const coord =
+        initialX ?? containerRect.left + containerRect.width - elWidth;
+      return createAnchoredInnerRight();
+    }
