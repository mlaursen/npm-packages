+  x: number;
+  width?: string | number;
+  minWidth?: number;
+  actualX: HorizontalPosition;
+}
+
+export function createHorizontalPosition(
+  options: CreateHorizontalPositionOptions
+): XPosition {
+  const {
+    x: position,
+    vw,
+    vwMargin,
+    xMargin,
+    width,
+    elWidth,
+    initialX,
+    containerRect,
+    disableSwapping,
+  } = options;
+
+  const screenRight = vw - vwMargin;
+  if (width !== "equal" && elWidth > screenRight - vwMargin) {
+    return {
