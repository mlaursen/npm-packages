+import { cnb } from "cnbuilder";
+
+import { bem } from "../utils/bem.js";
+
+const styles = bem("rmd-popover");
+
+/**
+ * @since 6.0.0
+ */
+export interface PopoverClassNameOptions {
+  className?: string;
+  active: boolean;
+}
+
+/**
