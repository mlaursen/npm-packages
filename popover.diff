diff --git a/packages/core/src/popover/getPosition.ts b/packages/core/src/popover/getPosition.ts
new file mode 100644
index 0000000000..9263f2c2d0
--- /dev/null
+++ b/packages/core/src/popover/getPosition.ts
@@ -0,0 +1,129 @@
+import { type CSSProperties } from "react";
+
+import { BELOW_CENTER_ANCHOR } from "../positioning/constants.js";
+import {
+  type FixedPositionOptions,
+  type HorizontalPosition,
+  type VerticalPosition,
+} from "../positioning/types.js";
+import {
+  findSizingContainer,
+  getElementRect,
+  getTransformOrigin,
+} from "../positioning/utils.js";
+import { getScrollbarWidth } from "../scroll/getScrollbarWidth.js";
+import { createHorizontalPosition } from "./createHorizontalPosition.js";
+
+/**
+ * This is used when there is no `container` element so that some styles can
+ * still be created. The main use-case for this is context menus and when the
+ * `initialX` and `initialY` options have been provided.
+ *
+ * @internal
+ * @since 5.0.0
+ */
+const FALLBACK_DOM_RECT: DOMRect = {
+  x: 0,
+  y: 0,
+  height: 0,
+  width: 0,
+  left: 0,
+  right: 0,
+  top: 0,
+  bottom: 0,
+  toJSON() {
+    // do nothing
+  },
+};
+
+export function getPosition(options: FixedPositionOptions): {
+  style: CSSProperties | undefined;
+  actualX: HorizontalPosition;
+  actualY: VerticalPosition;
+} {
+  const {
+    element,
+    anchor = BELOW_CENTER_ANCHOR,
+    initialX,
+    vwMargin = 16,
+    vhMargin = 16,
+    xMargin = 0,
+    yMargin = 0,
+    width: widthType = "auto",
+    preventOverlap = false,
+    transformOrigin = false,
+    disableSwapping = false,
+  } = options;
+  const { initialY } = options;
+  const container = findSizingContainer(options.container);
+  const containerRect = container?.getBoundingClientRect() ?? FALLBACK_DOM_RECT;
+
+  if (!element) {
+    let x = initialX ?? containerRect.x;
+    let y = initialY ?? containerRect.y;
+    x += window.scrollX;
+    y += window.scrollY;
+    return {
+      actualX: anchor.x,
+      actualY: anchor.y,
+      style: {
+        "--rmd-popover-x": `${x}px`,
+        "--rmd-popover-y": `${y}px`,
+        "--rmd-popover-transform-origin": transformOrigin
+          ? getTransformOrigin({ x: anchor.x, y: anchor.y })
+          : undefined,
+      } as CSSProperties,
+    };
+  }
+
+  const { minWidth: elMinWidth } = element.style;
+  // Note: This makes it "min-content" or "min-container-width"
+  if (widthType === "min") {
+    element.style.overflow = "visible";
+    element.style.minWidth = "";
+  }
+  const elementRect = getElementRect(element);
+  const { height } = elementRect;
+  let elWidth = elementRect.width;
+  if (widthType === "min") {
+    elWidth += getScrollbarWidth();
+    element.style.overflow = "";
+    element.style.minWidth = elMinWidth;
+  }
+
+  const { x, width, minWidth, actualX } = createHorizontalPosition({
+    x: anchor.x,
+    vw: window.innerWidth,
+    vwMargin,
+    xMargin,
+    width: widthType,
+    elWidth,
+    initialX,
+    containerRect,
+    disableSwapping,
+  });
+
+  // eslint-disable-next-line prefer-const
+  let actualY = anchor.y;
+  let transformOriginY: number | undefined;
+  // x = initialX ?? containerRect.x; // - elWidth / 2;
+  // y = initialY ?? containerRect.y - containerRect.height + height; // - height / 2;
+  // x += window.scrollX;
+  // y += window.scrollY;
+  let y = initialY ?? containerRect.y;
+  y += window.scrollY;
+
+  return {
+    actualX,
+    actualY,
+    style: {
+      "--rmd-popover-x": `${x}px`,
+      "--rmd-popover-y": `${y}px`,
+      "--rmd-popover-width": width,
+      "--rmd-popover-min-width": minWidth,
+      "--rmd-popover-transform-origin": transformOrigin
+        ? getTransformOrigin({ x: actualX, y: actualY, transformOriginY })
+        : undefined,
+    } as CSSProperties,
+  };
+}
